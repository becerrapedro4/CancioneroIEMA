let _fbApp=null,_fbDb=null;
function fbInit(){
  if(_fbDb)return _fbDb;
  try{
    _fbApp=firebase.initializeApp(FB_CONFIG,"cancionero");
    _fbDb=firebase.database(_fbApp);
  }catch(e){
    _fbDb=firebase.database();
  }
  return _fbDb;
