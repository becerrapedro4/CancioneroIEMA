<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Cancionero</title>
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/10.12.0/firebase-database-compat.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500&display=swap');
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0D0D0D;--surface:#161616;--surface2:#1E1E1E;
  --accent:#F5A623;--text:#F0EDE8;--muted:#6B6560;--border:#2A2A2A;
  --green:#4CAF7D;--red:#E05252;
}
html,body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;min-height:100vh;-webkit-text-size-adjust:100%}
.app{max-width:1100px;margin:0 auto;padding:0 16px 120px}
.loading{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:80vh;gap:16px;color:var(--muted)}
.spinner{width:36px;height:36px;border:2px solid var(--border);border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}

/* HEADER */
.header{padding:32px 0 0;user-select:none;-webkit-user-select:none}
.header-label{font-size:11px;font-weight:500;letter-spacing:3px;text-transform:uppercase;color:var(--accent);margin-bottom:6px}
.header-title{font-family:'Playfair Display',serif;font-size:clamp(28px,6vw,52px);font-weight:900;line-height:1;cursor:default}
.header-sub{margin-top:8px;color:var(--muted);font-size:13px}
.header-sub b{color:var(--accent);font-weight:500}
.db-tag{font-size:11px;opacity:.5;margin-left:8px}

/* TABS */
.tabs{display:flex;border-bottom:1px solid var(--border);margin:20px 0 0}
.tab{padding:12px 20px;font-size:13px;font-family:'DM Sans',sans-serif;background:none;border:none;border-bottom:2px solid transparent;color:var(--muted);cursor:pointer;margin-bottom:-1px;transition:color .15s,border-color .15s}
.tab.active{color:var(--accent);border-bottom-color:var(--accent);font-weight:500}
.badge{display:none;background:var(--accent);color:#000;border-radius:10px;font-size:10px;padding:1px 6px;margin-left:4px;vertical-align:middle}

/* VIEWS */
.view{display:none;padding-top:24px}
.view.active{display:block}

/* SEARCH */
.controls{display:flex;gap:10px;margin-bottom:14px;flex-wrap:wrap;align-items:center}
.search-wrap{flex:1;min-width:180px;position:relative}
.si{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--muted);font-style:normal;font-size:15px;pointer-events:none}
.search-input{width:100%;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:13px 12px 13px 38px;font-family:'DM Sans',sans-serif;font-size:16px;color:var(--text);outline:none;-webkit-appearance:none;transition:border-color .15s}
.search-input::placeholder{color:var(--muted)}
.search-input:focus{border-color:var(--accent)}
.btn-sel{padding:12px 16px;font-size:13px;font-family:'DM Sans',sans-serif;border:1px solid var(--border);border-radius:10px;cursor:pointer;background:transparent;color:var(--muted);white-space:nowrap;transition:all .15s}
.btn-sel.active{background:var(--accent);color:#000;font-weight:500;border-color:var(--accent)}
.rinfo{font-size:13px;color:var(--muted);margin-bottom:12px}
.rinfo b{color:var(--accent);font-weight:500}

/* SONG ROWS */
.song-list{display:flex;flex-direction:column;gap:1px}
.song-row{display:flex;align-items:center;gap:12px;padding:13px 12px;border-radius:10px;cursor:pointer;border:1px solid transparent;-webkit-tap-highlight-color:rgba(245,166,35,.1);transition:background .1s}
.song-row:active,.song-row.active{background:var(--surface2);border-color:var(--border)}
.song-row.selected{background:rgba(245,166,35,.07);border-color:rgba(245,166,35,.2)}
.snum{font-size:11px;color:var(--muted);min-width:26px;text-align:right;flex-shrink:0}
.sinfo{flex:1;min-width:0}
.stitle{font-size:14px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.stitle mark{background:rgba(245,166,35,.3);color:var(--text);border-radius:2px}
.sartist{font-size:12px;color:var(--muted);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ssnip{font-size:12px;color:var(--muted);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ssnip mark{background:rgba(245,166,35,.2);color:#d4c8b8;border-radius:2px}
.sarrow{color:var(--muted);font-size:18px;flex-shrink:0}
.schk{width:20px;height:20px;border-radius:6px;border:1.5px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:12px;transition:all .15s}
.song-row.selected .schk{background:var(--accent);border-color:var(--accent);color:#000}
.lm-wrap{text-align:center;padding:20px 0}
.lm-btn{background:transparent;border:1px solid var(--border);border-radius:8px;padding:11px 28px;color:var(--muted);font-family:'DM Sans',sans-serif;font-size:13px;cursor:pointer}
.empty{text-align:center;padding:60px 20px;color:var(--muted)}
.empty-icon{font-size:36px;margin-bottom:10px}
.empty-sub{font-size:13px;margin-top:6px}

/* DESKTOP */
@media(min-width:720px){
  .split{display:grid;grid-template-columns:1fr 380px;gap:16px;align-items:start}
  .detail-ov{position:sticky;top:16px;inset:auto;background:transparent;display:block;z-index:1;height:fit-content}
  .detail-ov.open{display:block}
  .dsheet{border-radius:16px;max-height:calc(100vh - 32px);border:1px solid var(--border)}
  .dhandle{display:none}
}

/* DETAIL */
.detail-ov{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:50;display:none;align-items:flex-end}
.detail-ov.open{display:flex}
.dsheet{background:var(--surface);border-radius:20px 20px 0 0;width:100%;max-height:88vh;display:flex;flex-direction:column;border-top:1px solid var(--border)}
.dhandle{width:40px;height:4px;background:var(--border);border-radius:2px;margin:12px auto 0}
.dheader{padding:16px 18px 14px;border-bottom:1px solid var(--border);display:flex;align-items:flex-start;gap:12px}
.dtitles{flex:1;min-width:0}
.dtitle{font-family:'Playfair Display',serif;font-size:18px;font-weight:700;line-height:1.2}
.dartist{font-size:12px;color:var(--accent);font-weight:500;margin-top:3px}
.dclose{background:none;border:none;color:var(--muted);font-size:22px;cursor:pointer;padding:0;line-height:1;flex-shrink:0}
.dbody{overflow-y:auto;padding:18px;flex:1;-webkit-overflow-scrolling:touch}
.lyric-block{margin-bottom:18px}
.lyric-desc{font-size:10px;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:5px}
.lyric-text{font-size:14px;line-height:1.9;white-space:pre-wrap;text-transform:uppercase}
.lyric-text mark{background:rgba(245,166,35,.3);color:var(--text);border-radius:2px}
.lyric-div{border:none;border-top:1px solid var(--border);margin:14px 0}

/* FLOAT BAR */
.fbar{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(120px);background:var(--surface2);border:1px solid rgba(245,166,35,.3);border-radius:16px;padding:13px 16px;display:flex;align-items:center;gap:10px;z-index:40;box-shadow:0 8px 32px rgba(0,0,0,.7);transition:transform .3s cubic-bezier(.34,1.56,.64,1);white-space:nowrap;flex-wrap:wrap;justify-content:center}
.fbar.visible{transform:translateX(-50%) translateY(0)}
.fbar-count{font-size:13px;color:var(--muted)}
.fbar-count b{color:var(--accent);font-weight:600}
.fbtn{padding:9px 16px;border-radius:9px;border:none;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;transition:opacity .15s;white-space:nowrap}
.fbtn.pri{background:var(--accent);color:#000}
.fbtn.sec{background:transparent;border:1px solid var(--border);color:var(--muted)}
.fbtn:hover{opacity:.8}

/* LISTS */
.lists-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
.lists-hdr-title{font-family:'Playfair Display',serif;font-size:22px;font-weight:700}
.btn-newlist{background:var(--accent);color:#000;border:none;border-radius:9px;padding:10px 18px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer}
.lcard{background:var(--surface);border:1px solid var(--border);border-radius:14px;overflow:hidden;margin-bottom:10px;transition:border-color .15s}
.lcard.expanded{border-color:rgba(245,166,35,.3)}
.lcard-hdr{display:flex;align-items:center;gap:12px;padding:16px;cursor:pointer;-webkit-tap-highlight-color:transparent}
.lcard-chev{color:var(--muted);font-size:14px;transition:transform .2s;flex-shrink:0}
.lcard.expanded .lcard-chev{transform:rotate(90deg)}
.lcard-name{font-weight:500;font-size:15px;flex:1}
.lcard-cnt{font-size:12px;color:var(--muted);flex-shrink:0}
.lcard-acts{display:flex;gap:6px;flex-shrink:0}
.lca{background:transparent;border:1px solid var(--border);border-radius:7px;padding:6px 10px;font-size:12px;color:var(--muted);font-family:'DM Sans',sans-serif;cursor:pointer;transition:all .15s;white-space:nowrap}
.lca:hover{border-color:var(--accent);color:var(--accent)}
.lca.danger:hover{border-color:var(--red);color:var(--red)}
.lcard-body{display:none;border-top:1px solid var(--border)}
.lcard.expanded .lcard-body{display:block}
.lcard-songs{padding:8px}
.lcsr{display:flex;align-items:center;gap:10px;padding:10px;border-radius:8px;cursor:pointer}
.lcsr:hover{background:var(--surface2)}
.lcsn{font-size:11px;color:var(--muted);min-width:22px;text-align:right;flex-shrink:0}
.lcsi{flex:1;min-width:0}
.lcst{font-size:14px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.lcsa{font-size:12px;color:var(--muted);margin-top:1px}
.lcs-rm{background:none;border:none;color:var(--muted);font-size:18px;cursor:pointer;padding:0 4px;flex-shrink:0;transition:color .1s}
.lcs-rm:hover{color:var(--red)}
.lcard-export{display:flex;gap:8px;padding:12px;border-top:1px solid var(--border);flex-wrap:wrap}
.exp-btn{flex:1;min-width:120px;padding:10px 14px;border-radius:9px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;transition:opacity .15s;border:none}
.exp-btn.html{background:rgba(245,166,35,.15);color:var(--accent);border:1px solid rgba(245,166,35,.3)}
.exp-btn.pdf{background:var(--accent);color:#000}
.exp-btn:hover{opacity:.8}

/* MODALS */
.mov{position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:100;display:none;align-items:center;justify-content:center;padding:20px}
.mov.open{display:flex}
.modal{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:28px;width:100%;max-width:400px}
.modal.wide{max-width:680px;max-height:90vh;display:flex;flex-direction:column}
.modal-title{font-family:'Playfair Display',serif;font-size:20px;font-weight:700;margin-bottom:6px}
.modal-sub{font-size:13px;color:var(--muted);margin-bottom:22px}
.mclose{float:right;background:none;border:none;color:var(--muted);font-size:22px;cursor:pointer;margin-top:-4px}
.minput{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:13px 14px;font-family:'DM Sans',sans-serif;font-size:15px;color:var(--text);outline:none;margin-bottom:16px;-webkit-appearance:none;transition:border-color .15s}
.minput:focus{border-color:var(--accent)}
.mactions{display:flex;gap:10px;flex-wrap:wrap}
.mbtn{flex:1;padding:12px 16px;border-radius:9px;border:none;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;min-width:100px}
.mbtn.pri{background:var(--accent);color:#000}
.mbtn.sec{background:transparent;border:1px solid var(--border);color:var(--muted)}
.mbtn.danger{background:rgba(224,82,82,.12);color:var(--red);border:1px solid rgba(224,82,82,.25)}
.mstatus{font-size:13px;padding:10px 14px;border-radius:8px;margin-bottom:16px;display:none}
.mstatus.ok{background:rgba(76,175,125,.15);color:var(--green);border:1px solid rgba(76,175,125,.3);display:block}
.mstatus.err{background:rgba(224,82,82,.15);color:var(--red);border:1px solid rgba(224,82,82,.3);display:block}
.upload-zone{border:1.5px dashed var(--border);border-radius:12px;padding:28px 20px;text-align:center;cursor:pointer;transition:border-color .15s,background .15s;margin-bottom:16px}
.upload-zone:hover{border-color:var(--accent);background:rgba(245,166,35,.04)}

/* ATL */
.atl-list{display:flex;flex-direction:column;gap:6px;margin-bottom:16px;max-height:220px;overflow-y:auto}
.atl-item{display:flex;align-items:center;gap:10px;padding:11px 14px;background:var(--surface2);border:1px solid var(--border);border-radius:10px;cursor:pointer;transition:border-color .15s}
.atl-item:hover{border-color:var(--accent)}
.atl-name{flex:1;font-size:14px;font-weight:500}
.atl-cnt{font-size:12px;color:var(--muted)}

/* ADMIN DB EDITOR */
.admin-tabs{display:flex;gap:0;border-bottom:1px solid var(--border);margin-bottom:20px}
.admin-tab{padding:10px 16px;font-size:13px;font-family:'DM Sans',sans-serif;background:none;border:none;border-bottom:2px solid transparent;color:var(--muted);cursor:pointer;margin-bottom:-1px;transition:color .15s}
.admin-tab.active{color:var(--accent);border-bottom-color:var(--accent);font-weight:500}
.admin-panel{display:none}
.admin-panel.active{display:block}
.admin-search{width:100%;background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:11px 14px;font-family:'DM Sans',sans-serif;font-size:14px;color:var(--text);outline:none;margin-bottom:12px;-webkit-appearance:none}
.admin-search:focus{border-color:var(--accent)}
.admin-song-list{flex:1;overflow-y:auto;display:flex;flex-direction:column;gap:1px;margin-bottom:12px;max-height:340px}
.admin-row{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:8px;cursor:pointer;border:1px solid transparent;transition:background .1s}
.admin-row:hover{background:var(--surface2)}
.admin-row.marked{background:rgba(224,82,82,.08);border-color:rgba(224,82,82,.2)}
.admin-chk{width:18px;height:18px;border-radius:5px;border:1.5px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:11px;transition:all .15s}
.admin-row.marked .admin-chk{background:var(--red);border-color:var(--red);color:#fff}
.admin-info{flex:1;min-width:0}
.admin-st{font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.admin-sa{font-size:11px;color:var(--muted)}
.admin-footer{display:flex;align-items:center;gap:10px;flex-wrap:wrap;padding-top:12px;border-top:1px solid var(--border)}
.admin-sel-count{font-size:13px;color:var(--muted);flex:1}
.admin-sel-count b{color:var(--red);font-weight:600}

/* DETAIL FOOTER */
.dfooter{display:flex;gap:8px;padding:12px 16px;border-top:1px solid var(--border);flex-shrink:0}
.dfbtn{flex:1;padding:10px 12px;border-radius:9px;border:none;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;transition:opacity .15s}
.dfbtn.edit{background:rgba(245,166,35,.12);color:var(--accent);border:1px solid rgba(245,166,35,.25)}
.dfbtn.del{background:rgba(224,82,82,.1);color:var(--red);border:1px solid rgba(224,82,82,.2)}
.dfbtn:hover{opacity:.75}

/* EDIT MODAL */
.paras-list{max-height:280px;overflow-y:auto;margin-bottom:10px}
.para-item{background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:12px 12px 8px;margin-bottom:8px;position:relative}
.para-label-input{width:100%;background:transparent;border:none;border-bottom:1px solid var(--border);font-family:'DM Sans',sans-serif;font-size:11px;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:var(--muted);outline:none;margin-bottom:8px;padding:0 28px 6px 0;-webkit-appearance:none}
.para-textarea{width:100%;background:transparent;border:none;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--text);outline:none;resize:vertical;min-height:80px;line-height:1.7;-webkit-appearance:none}
.para-rm{position:absolute;top:10px;right:10px;background:none;border:none;color:var(--muted);cursor:pointer;font-size:18px;padding:0;line-height:1;transition:color .1s}
.para-rm:hover{color:var(--red)}

/* LONG PRESS feedback */
.song-row{transition:background .1s,transform .1s}
.song-row.pressing{background:rgba(245,166,35,.08)!important;transform:scale(.985)}

/* GEAR BTN */
#btn-settings{position:fixed;top:14px;right:14px;z-index:200;background:var(--surface2);border:1px solid var(--border);border-radius:50%;width:42px;height:42px;font-size:19px;cursor:pointer;display:flex;align-items:center;justify-content:center;line-height:1;transition:border-color .2s,transform .3s;box-shadow:0 2px 12px rgba(0,0,0,.6)}
#btn-settings:hover{border-color:var(--accent);transform:rotate(60deg)}

/* COLOR PICKER */
.color-pick-wrap{display:flex;align-items:center;gap:6px;padding:8px 12px;border:1px solid var(--border);border-radius:9px;background:transparent;cursor:pointer;transition:border-color .15s}
.color-pick-wrap:hover{border-color:var(--accent)}
.color-pick-label{font-size:12px;color:var(--muted);white-space:nowrap}
.list-color-pick{width:26px;height:26px;border:none;border-radius:5px;cursor:pointer;padding:0;background:none}

/* STYLE PICKER */
.style-pick{display:flex;gap:4px;flex-wrap:wrap}
.spbtn{padding:6px 11px;border-radius:7px;border:1px solid var(--border);font-family:'DM Sans',sans-serif;font-size:12px;color:var(--muted);background:transparent;cursor:pointer;transition:all .15s;white-space:nowrap}
.spbtn.active{background:rgba(245,166,35,.12);border-color:rgba(245,166,35,.4);color:var(--accent)}

/* ADMIN-ONLY: hidden until isAdmin */
.admin-only{display:none!important}

/* PRESENTER */
.pres-live{display:flex;align-items:center;gap:7px;margin-bottom:16px}
.pres-dot{width:8px;height:8px;border-radius:50%;background:var(--red);animation:pdot 1.4s ease-in-out infinite}
@keyframes pdot{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.7)}}
.pres-live-label{font-size:12px;color:var(--red);font-weight:500;letter-spacing:1px;text-transform:uppercase}
.pres-song{font-size:13px;color:var(--accent);font-weight:500;text-transform:uppercase;letter-spacing:1px;margin-bottom:14px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pres-box{background:var(--surface2);border:1px solid var(--border);border-radius:12px;padding:18px;min-height:110px;margin-bottom:14px;transition:border-color .2s}
.pres-box.blank-on{border-color:var(--red);opacity:.5}
.pres-blabel{font-size:10px;letter-spacing:3px;text-transform:uppercase;color:var(--muted);margin-bottom:8px}
.pres-btext{font-size:13px;line-height:1.9;text-transform:uppercase;color:var(--text);white-space:pre-wrap}
.pres-nav{display:flex;align-items:center;gap:10px;margin-bottom:14px}
.pres-arr{flex:0 0 44px;height:44px;border-radius:10px;border:1px solid var(--border);background:transparent;color:var(--text);font-size:20px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s}
.pres-arr:hover:not(:disabled){border-color:var(--accent);color:var(--accent)}
.pres-arr:disabled{opacity:.25;cursor:default}
.pres-dots{flex:1;display:flex;justify-content:center;gap:5px;flex-wrap:wrap}
.pdot-item{width:7px;height:7px;border-radius:50%;background:var(--border);transition:background .2s;cursor:pointer}
.pdot-item.active{background:var(--accent)}
.pres-btns{display:flex;gap:8px}
.pres-blank{flex:1;padding:11px;border-radius:9px;border:1px solid var(--border);background:transparent;font-family:'DM Sans',sans-serif;font-size:13px;color:var(--muted);cursor:pointer;transition:all .2s}
.pres-blank.on{background:rgba(224,82,82,.12);border-color:rgba(224,82,82,.4);color:var(--red)}
.pres-stop{padding:11px 16px;border-radius:9px;border:none;background:var(--surface2);font-family:'DM Sans',sans-serif;font-size:13px;color:var(--muted);cursor:pointer;transition:opacity .15s}
.pres-stop:hover{opacity:.7}
.dfbtn.present{background:rgba(76,175,125,.12);color:var(--green);border:1px solid rgba(76,175,125,.3)}
</style>
</head>
<body>

<div id="loading" class="loading"><div class="spinner"></div><span>Cargando canciones…</span></div>

<button id="btn-settings" title="Configuración">⚙️</button>

<div id="app" class="app" style="display:none">
  <div class="header">
    <div class="header-label">Cancionero</div>
    <h1 class="header-title" id="header-tap">Buscador<br>de Canciones</h1>
    <p class="header-sub"><b id="total-count"></b> canciones<span class="db-tag" id="db-tag"></span></p>
  </div>

  <div class="tabs">
    <button class="tab active" data-view="search">Canciones</button>
    <button class="tab" data-view="lists">Mis Listas <span class="badge" id="lists-badge"></span></button>
