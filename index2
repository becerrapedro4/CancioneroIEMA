/* PRESENTER STATE */
let _presRoom=localStorage.getItem("pres_room")||"",_presSong=null,_presIdx=0,_presBlank=false,_presStanzas=[];

function presStanzas(song){
  if(song.p&&song.p.length)return song.p.map(p=>({d:p.d||"",x:p.x||""}));
  const raw=song.l||"";
  return raw.split(/\n{2,}/).map((x,i)=>({d:`Estrofa ${i+1}`,x:x.trim()})).filter(s=>s.x);
}

function presWrite(blank){
  const db=fbInit();if(!db||!_presRoom)return;
  const stanza=_presStanzas[_presIdx]||{d:"",x:""};
  db.ref(`rooms/${_presRoom}/currentSong`).set({
    id:_presSong.id,
    titulo:_presSong.t||"",
    estrofa:stanza.x,
    label:stanza.d,
    idx:_presIdx,
    total:_presStanzas.length,
    blank:blank||false,
    ts:Date.now()
  });
}

function presRenderUI(){
  const stanza=_presStanzas[_presIdx]||{d:"",x:""};
  document.getElementById("pres-title").textContent=_presSong?.t||"";
  document.getElementById("pres-blabel").textContent=stanza.d;
  document.getElementById("pres-btext").textContent=stanza.x;
  document.getElementById("pres-box").classList.toggle("blank-on",_presBlank);
  document.getElementById("pres-prev").disabled=_presIdx===0;
  document.getElementById("pres-next").disabled=_presIdx===_presStanzas.length-1;
  // dots
  const dots=document.getElementById("pres-dots");
  dots.innerHTML=_presStanzas.map((_,i)=>`<div class="pdot-item${i===_presIdx?" active":""}" data-i="${i}"></div>`).join("");
  dots.querySelectorAll(".pdot-item").forEach(d=>d.addEventListener("click",()=>{_presIdx=+d.dataset.i;presRenderUI();presWrite(_presBlank);}));
  // blank btn label
  document.getElementById("pres-blank").classList.toggle("on",_presBlank);
  document.getElementById("pres-blank").textContent=_presBlank?"▶ Mostrar letra":"⬜ Pantalla en blanco";
}

function openPresenter(song){
  const db=fbInit();if(!db)return;
  // ask room if not set
  if(!_presRoom){
    const r=prompt("Nombre de la sala (comparte este nombre con el viewer):", "iglesia");
    if(!r)return;
    _presRoom=r.trim().replace(/[^a-zA-Z0-9_-]/g,"_");
    localStorage.setItem("pres_room",_presRoom);
  }
  _presSong=song;
  _presIdx=0;
  _presBlank=false;
  _presStanzas=presStanzas(song);
  presRenderUI();
  presWrite(false);
  document.getElementById("mov-pres").classList.add("open");
  updateSettingsBtn();
}

/* presenter button events */
document.getElementById("d-present").addEventListener("click",()=>{if(_detailSong)openPresenter(_detailSong);});
document.getElementById("pres-close").addEventListener("click",()=>{document.getElementById("mov-pres").classList.remove("open");updateSettingsBtn();});
document.getElementById("pres-prev").addEventListener("click",()=>{if(_presIdx>0){_presIdx--;presRenderUI();presWrite(_presBlank);}});
document.getElementById("pres-next").addEventListener("click",()=>{if(_presIdx<_presStanzas.length-1){_presIdx++;presRenderUI();presWrite(_presBlank);}});
document.getElementById("pres-blank").addEventListener("click",()=>{_presBlank=!_presBlank;presRenderUI();presWrite(_presBlank);});
document.getElementById("pres-stop").addEventListener("click",()=>{
  if(!_presRoom)return;
  const db=fbInit();if(db)db.ref(`rooms/${_presRoom}/currentSong`).set({blank:true,ts:Date.now(),stop:true});
  document.getElementById("mov-pres").classList.remove("open");
  updateSettingsBtn();
});
// swipe on pres-box
(()=>{let sx=0;const box=document.getElementById("pres-box");
box.addEventListener("touchstart",e=>{sx=e.touches[0].clientX;},{passive:true});
box.addEventListener("touchend",e=>{
  const dx=e.changedTouches[0].clientX-sx;
  if(Math.abs(dx)<50)return;
  if(dx<0&&_presIdx<_presStanzas.length-1){_presIdx++;presRenderUI();presWrite(_presBlank);}
  if(dx>0&&_presIdx>0){_presIdx--;presRenderUI();presWrite(_presBlank);}
},{passive:true});})();

// keyboard shortcuts when presenter is open
document.addEventListener("keydown",e=>{
  if(!document.getElementById("mov-pres").classList.contains("open"))return;
  if(e.key==="ArrowRight"||e.key==="ArrowDown"){if(_presIdx<_presStanzas.length-1){_presIdx++;presRenderUI();presWrite(_presBlank);}}
  if(e.key==="ArrowLeft"||e.key==="ArrowUp"){if(_presIdx>0){_presIdx--;presRenderUI();presWrite(_presBlank);}}
  if(e.key===" "){e.preventDefault();_presBlank=!_presBlank;presRenderUI();presWrite(_presBlank);}
});

/* ── INIT ── */
(async()=>{
  loadLists();
  loadDeletedIds();
  let localData;

  // 1. Cargar base local
  try{const s=localStorage.getItem("holyrics_db");if(s){localData=JSON.parse(s);document.getElementById("db-tag").textContent="(local)";}}catch{}

  if(localData)SONGS=localData.map(s=>s.title!==undefined?slimSong(s):s);
  else SONGS=[];

  // 2. Intentar cargar del repo y hacer MERGE (agrega nuevas, respeta eliminadas)
  try{
    const res=await fetch("canciones.json");
    if(!res.ok)throw new Error("HTTP "+res.status);
    const raw=await res.json();
    const existingIds=new Set(SONGS.map(s=>s.id));
    const newSongs=raw.map(slimSong).filter(s=>!existingIds.has(s.id)&&!deletedIds.has(s.id));
    if(newSongs.length){
      SONGS=[...SONGS,...newSongs];
      saveDB();
      document.getElementById("db-tag").textContent=`(+${newSongs.length} del repo)`;
    }else if(!localData){
      document.getElementById("db-tag").textContent="(repo)";
    }
  }catch(e){if(!localData)console.warn("No se pudo cargar canciones.json:",e);}

  updateCount();applyFilter();renderSongList();updateBadge();
  document.getElementById("loading").style.display="none";
  document.getElementById("app").style.display="";
})();
</script>
