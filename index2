<script>
function esc(s){return String(s).replace(/[&<>"]/g,c=>({'&':'&','<':'<','>':'>','"':'&quot;'}[c]));}
function hlHtml(text,q){
  if(!q||q.length<2)return esc(text);
  const re=new RegExp(q.replace(/[.*+?^${}()|[\]\\]/g,"\\$&"),"gi");
  return esc(text).replace(re,m=>`<mark>${m}</mark>`);
}
function snip(text,q){
  if(!q||q.length<2||!text)return null;
  const i=text.toLowerCase().indexOf(q.toLowerCase());
  if(i===-1)return null;
  const s=Math.max(0,i-25),e=Math.min(text.length,i+q.length+45);
  return(s>0?"…":"")+text.slice(s,e)+(e<text.length?"…":"");
}
function slimSong(s){
  return{id:s.id,t:s.title||s.t||"",a:s.artist||s.a||"",
    l:s.lyrics?.full_text||s.l||"",
    p:s.lyrics?.paragraphs?.map(p=>({d:p.description||p.d||"",x:p.text||p.x||""}))||s.p||[]};
}
function toHolyricsFormat(s){
  return{id:s.id,title:s.t,artist:s.a,author:"",note:"",copyright:"",language:"",key:"",bpm:0.0,time_sig:"",midi:null,order:"",arrangements:[],
    lyrics:{full_text:s.l,full_text_with_comment:null,
      paragraphs:s.p.map((par,i)=>({number:i+1,description:par.d,text:par.x,text_with_comment:null,translations:null}))},
    streaming:null,extras:null};
}
function uid(){return Date.now()+"_"+Math.random().toString(36).slice(2,7);}

/* STATE */
let SONGS=[],filtered=[],query="",page=1,selectMode=false,selected=new Set();
let LISTS=[];
const PAGE=60;
let deleteMarked=new Set();
let isAdmin=false;
let deletedIds=new Set();

/* ADMIN UI */
function applyAdminUI(){
  document.querySelectorAll(".admin-only").forEach(el=>{
    el.classList.toggle("admin-only",!isAdmin);
    if(isAdmin)el.style.removeProperty("display");
  });
  // Si recién se activó admin, re-render listas para mostrar export
  renderLists();
}
function updateSettingsBtn(){
  const anyOpen=document.querySelector(".mov.open");
  document.getElementById("btn-settings").style.opacity=anyOpen?"0":"1";
  document.getElementById("btn-settings").style.pointerEvents=anyOpen?"none":"auto";
}

/* PERSIST */
function saveDB(){localStorage.setItem("holyrics_db",JSON.stringify(SONGS));}
function saveLists(){localStorage.setItem("holyrics_lists",JSON.stringify(LISTS));}
function loadLists(){try{const s=localStorage.getItem("holyrics_lists");if(s)LISTS=JSON.parse(s);}catch{}if(!Array.isArray(LISTS))LISTS=[];}
function saveDeletedIds(){localStorage.setItem("holyrics_deleted",JSON.stringify([...deletedIds]));}
function loadDeletedIds(){try{const s=localStorage.getItem("holyrics_deleted");if(s)deletedIds=new Set(JSON.parse(s));}catch{}}

/* FILTER & RENDER */
function applyFilter(){
  const q=query.trim().toLowerCase();
  filtered=!q?SONGS:SONGS.filter(s=>
    (s.t||"").toLowerCase().includes(q)||(s.l||"").toLowerCase().includes(q)
  );
}
function renderInfo(){
  const t=filtered.length,sh=Math.min(page*PAGE,t);
  const el=document.getElementById("rinfo");
  el.innerHTML=query.trim().length>=2
    ?`<b>${t}</b> resultado${t!==1?"s":""} para "${esc(query.trim())}"`
    :`<b>${sh}</b> de <b>${t}</b> canciones`;
}
function renderSongList(){
  const q=query.trim(),items=filtered.slice(0,page*PAGE),el=document.getElementById("song-list");
  el.innerHTML=!items.length
    ?`<div class="empty"><div class="empty-icon">🎶</div><div>Sin resultados</div></div>`
    :items.map((s,i)=>{
      const idx=SONGS.indexOf(s),sn=snip(s.l,q),isSel=selected.has(s.id);
      return`<div class="song-row${isSel?" selected":""}" data-idx="${idx}">
        ${selectMode?`<div class="schk">${isSel?"✓":""}</div>`:`<span class="snum">${i+1}</span>`}
        <div class="sinfo">
          <div class="stitle">${hlHtml(s.t||"Sin título",q)}</div>
          ${s.a?`<div class="sartist">${esc(s.a)}</div>`:""}
          ${sn?`<div class="ssnip">${hlHtml(sn,q)}</div>`:""}
        </div>
        ${!selectMode?`<span class="sarrow">›</span>`:""}
      </div>`;
    }).join("");
  document.getElementById("lm-wrap").style.display=filtered.length>page*PAGE?"":"none";
  document.getElementById("lm-btn").textContent=`Cargar más (${filtered.length-page*PAGE} restantes)`;
  renderInfo();updateFbar();
}
function updateFbar(){
  document.getElementById("sel-count").textContent=selected.size;
  document.getElementById("fbar").classList.toggle("visible",selectMode&&selected.size>0);
}
function updateCount(){document.getElementById("total-count").textContent=SONGS.length.toLocaleString();}
function updateBadge(){
  const b=document.getElementById("lists-badge");
  b.textContent=LISTS.length;b.style.display=LISTS.length?"":"none";
}

/* DETAIL */
let _detailSong=null;
function showDetail(song){
  _detailSong=song;
  const q=query.trim();
  document.getElementById("d-title").textContent=song.t||"";
  document.getElementById("d-artist").textContent=song.a||"";
  document.getElementById("d-artist").style.display=song.a?"":"none";
  document.getElementById("d-body").innerHTML=song.p?.length
    ?song.p.map((par,i)=>`<div class="lyric-block">${par.d?`<div class="lyric-desc">${esc(par.d)}</div>`:""}<div class="lyric-text">${hlHtml(par.x||"",q)}</div>${i<song.p.length-1?'<hr class="lyric-div">':""}</div>`).join("")
    :`<div style="color:var(--muted);font-size:14px">Sin letra</div>`;
  document.getElementById("detail-ov").classList.add("open");
}

/* LISTS */
function renderLists(){
  updateBadge();
  const c=document.getElementById("lists-con");
  if(!LISTS.length){
    c.innerHTML=`<div class="empty"><div class="empty-icon">🗂️</div><div>Todavía no tenés listas</div><div class="empty-sub">Seleccioná canciones y guardalas en una lista</div></div>`;
    return;
  }
  c.innerHTML=LISTS.map(lst=>{
    const songs=lst.songIds.map(id=>SONGS.find(s=>s.id===id)).filter(Boolean);
    return`<div class="lcard" id="lc-${lst.id}">
      <div class="lcard-hdr" data-lid="${lst.id}">
        <span class="lcard-chev">›</span>
        <span class="lcard-name">${esc(lst.name)}</span>
        <span class="lcard-cnt">${songs.length} canc.</span>
        <div class="lcard-acts" onclick="event.stopPropagation()">
          <button class="lca" onclick="renameList('${lst.id}')">✏️</button>
          <button class="lca danger" onclick="deleteList('${lst.id}')">🗑️</button>
        </div>
      </div>
      <div class="lcard-body">
        <div class="lcard-songs">
          ${songs.length?songs.map((s,i)=>`
            <div class="lcsr" data-sid="${s.id}" data-lid="${lst.id}">
              <span class="lcsn">${i+1}</span>
              <div class="lcsi"><div class="lcst">${esc(s.t||"Sin título")}</div>${s.a?`<div class="lcsa">${esc(s.a)}</div>`:""}</div>
              <button class="lcs-rm" onclick="rmFromList('${lst.id}',${s.id},event)">×</button>
            </div>`).join("")
          :`<div style="padding:16px;color:var(--muted);font-size:13px;text-align:center">Lista vacía</div>`}
        </div>
        <div class="lcard-export admin-only">
          <div class="style-pick" onclick="event.stopPropagation()">
            <button class="spbtn${(lst.style||'aesthetic')==='minimal'?' active':''}" data-lid="${lst.id}" data-style="minimal">Minimalista</button>
            <button class="spbtn${(lst.style||'aesthetic')==='aesthetic'?' active':''}" data-lid="${lst.id}" data-style="aesthetic">Aesthetic</button>
            <button class="spbtn${(lst.style||'aesthetic')==='glass'?' active':''}" data-lid="${lst.id}" data-style="glass">Glass</button>
          </div>
          <label class="color-pick-wrap" onclick="event.stopPropagation()">
            <span class="color-pick-label">Color:</span>
            <input type="color" class="list-color-pick" data-lid="${lst.id}" value="${lst.color||'#E55A00'}">
          </label>
          <button class="exp-btn html" onclick="exportList('${lst.id}','html')">⬇ HTML</button>
          <button class="exp-btn pdf" onclick="exportList('${lst.id}','pdf')">🖨 Imprimir</button>
        </div>
      </div>
    </div>`;
  }).join("");
  document.querySelectorAll(".lcard-hdr").forEach(h=>{
    h.addEventListener("click",()=>document.getElementById("lc-"+h.dataset.lid).classList.toggle("expanded"));
  });
  document.querySelectorAll(".lcsr").forEach(row=>{
    row.addEventListener("click",e=>{
      if(e.target.closest(".lcs-rm"))return;
      const song=SONGS.find(s=>s.id===Number(row.dataset.sid));
      if(song)showDetail(song);
    });
  });
  document.querySelectorAll(".list-color-pick").forEach(inp=>{
    inp.addEventListener("change",()=>{
      const l=LISTS.find(x=>x.id===inp.dataset.lid);
      if(l){l.color=inp.value;saveLists();}
    });
  });
  document.querySelectorAll(".spbtn").forEach(btn=>{
    btn.addEventListener("click",e=>{
      e.stopPropagation();
      const l=LISTS.find(x=>x.id===btn.dataset.lid);
      if(!l)return;
      l.style=btn.dataset.style;saveLists();
      btn.closest(".style-pick").querySelectorAll(".spbtn").forEach(b=>b.classList.toggle("active",b===btn));
    });
  });
}
function addToList(listId,ids){
  const l=LISTS.find(x=>x.id===listId);if(!l)return;
  ids.forEach(id=>{if(!l.songIds.includes(id))l.songIds.push(id);});
  saveLists();renderLists();
}
function rmFromList(lid,sid,e){
  e.stopPropagation();
  const l=LISTS.find(x=>x.id===lid);if(!l)return;
  l.songIds=l.songIds.filter(id=>id!==sid);saveLists();renderLists();
}
function deleteList(lid){
  if(!confirm("¿Eliminar esta lista?"))return;
  LISTS=LISTS.filter(l=>l.id!==lid);saveLists();renderLists();
}
function renameList(lid){
  const l=LISTS.find(x=>x.id===lid);if(!l)return;
  openNameModal(l.name,n=>{l.name=n;saveLists();renderLists();});
}

/* EXPORT LIST */
function buildExportHTML(lst){
  const songs=lst.songIds.map(id=>SONGS.find(s=>s.id===id)).filter(Boolean);
  const songsData=JSON.stringify(songs.map(s=>({
    title:s.t||"Sin título",
    letra:(s.p?.length?s.p.map(p=>p.x||"").join("\n\n"):s.l||""),
    stanzas:(s.p||[]).map(p=>({d:p.d||"",x:p.x||""}))
  })));
  const hex=lst.color||"#E55A00";
  const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
  const c1=`rgba(${Math.max(0,r-50)},${Math.max(0,g-40)},${b},0.6)`;
  const c2=`rgba(${r},${g},${b},0.3)`;
  const style=lst.style||"aesthetic";

  // ─── SHARED accordion script (injected into all templates) ──────────────────
  const acScript=`<script>
    const songs=${songsData};
    document.addEventListener('DOMContentLoaded',()=>{
      const list=document.getElementById('song-list');
      songs.forEach((s,i)=>{
        const wrap=document.createElement('div');
        wrap.className='ac-item';
        const stanzasHTML=s.stanzas&&s.stanzas.length
          ?s.stanzas.map(p=>\`<div class="stanza">\${p.d?\`<div class="stanza-label">\${p.d}<\/div>\`:''}
            <div class="stanza-text">\${p.x}<\/div><\/div>\`).join('')
          :\`<div class="stanza"><div class="stanza-text">\${s.letra}<\/div><\/div>\`;
        wrap.innerHTML=\`<div class="ac-hdr">
          <span class="ac-num">\${String(i+1).padStart(2,'0')}<\/span>
          <span class="ac-title">\${s.title}<\/span>
          <span class="ac-icon">+<\/span>
        <\/div>
        <div class="ac-body"><div class="ac-inner">\${stanzasHTML}<\/div><\/div>\`;
        wrap.querySelector('.ac-hdr').addEventListener('click',()=>{
          const open=wrap.classList.contains('open');
          document.querySelectorAll('.ac-item.open').forEach(x=>x.classList.remove('open'));
          if(!open)wrap.classList.add('open');
        });
        list.appendChild(wrap);
      });
    });
  <\/script>`;

  // ─────────────────────────────────────────────────────────────────────────────
  // TEMPLATE 1 — MINIMALISTA
  // ─────────────────────────────────────────────────────────────────────────────
  if(style==="minimal") return`<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>${lst.name}</title>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--a:${hex};--bg:#080808;--tx:#DEDAD4;--mu:#444;--br:#1C1C1C}
    html{scroll-behavior:smooth}
    body{background:var(--bg);color:var(--tx);font-family:system-ui,-apple-system,sans-serif;min-height:100vh}

    /* HEADER */
    header{padding:72px 28px 56px;max-width:680px;margin:0 auto}
    .hl{font-size:10px;letter-spacing:4px;text-transform:uppercase;color:var(--a);margin-bottom:18px}
    h1{font-size:clamp(36px,9vw,72px);font-weight:700;line-height:1.0;letter-spacing:-1px}
    h1 span{color:var(--a)}
    .hc{margin-top:14px;font-size:13px;color:var(--mu)}

    /* ACCORDION */
    main{max-width:680px;margin:0 auto;padding:0 28px 100px}
    .ac-item{border-top:1px solid var(--br)}
    .ac-item:last-child{border-bottom:1px solid var(--br)}
    .ac-hdr{display:flex;align-items:center;gap:18px;padding:22px 0;cursor:pointer;user-select:none}
    .ac-num{font-size:11px;color:var(--mu);min-width:22px;font-variant-numeric:tabular-nums}
    .ac-title{flex:1;font-size:16px;font-weight:500;transition:color .2s}
    .ac-item:hover .ac-title,.ac-item.open .ac-title{color:var(--a)}
    .ac-icon{font-size:22px;color:var(--mu);transition:transform .3s,color .2s;line-height:1}
    .ac-item.open .ac-icon{transform:rotate(45deg);color:var(--a)}
    .ac-body{max-height:0;overflow:hidden;transition:max-height .4s cubic-bezier(.4,0,.2,1)}
    .ac-item.open .ac-body{max-height:3000px}
    .ac-inner{padding:0 0 32px 40px}
