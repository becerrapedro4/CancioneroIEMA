  document.getElementById("del-count").textContent=deleteMarked.size;
  const q=delQuery.trim().toLowerCase();
  const items=!q?SONGS:SONGS.filter(s=>(s.t||"").toLowerCase().includes(q)||(s.a||"").toLowerCase().includes(q));
  document.getElementById("del-list").innerHTML=items.map(s=>{
    const marked=deleteMarked.has(s.id);
    return`<div class="admin-row${marked?" marked":""}" data-id="${s.id}">
      <div class="admin-chk">${marked?"✕":""}</div>
      <div class="admin-info">
        <div class="admin-st">${esc(s.t||"Sin título")}</div>
        ${s.a?`<div class="admin-sa">${esc(s.a)}</div>`:""}
      </div>
    </div>`;
  }).join("");
  document.querySelectorAll("#del-list .admin-row").forEach(row=>{
    row.addEventListener("click",()=>{
      const id=Number(row.dataset.id);
      if(deleteMarked.has(id)){deleteMarked.delete(id);row.classList.remove("marked");row.querySelector(".admin-chk").textContent="";}
      else{deleteMarked.add(id);row.classList.add("marked");row.querySelector(".admin-chk").textContent="✕";}
      document.getElementById("del-count").textContent=deleteMarked.size;
    });
  });
}
document.getElementById("del-search").addEventListener("input",e=>{delQuery=e.target.value;renderDelList();});
document.getElementById("del-clear").addEventListener("click",()=>{deleteMarked.clear();renderDelList();});
document.getElementById("del-confirm").addEventListener("click",()=>{
  if(!deleteMarked.size)return;
  if(!confirm(`¿Eliminar ${deleteMarked.size} canción${deleteMarked.size!==1?"es":""}? Esta acción no se puede deshacer.`))return;
  deleteMarked.forEach(id=>deletedIds.add(id));saveDeletedIds();
  SONGS=SONGS.filter(s=>!deleteMarked.has(s.id));
  deleteMarked.clear();saveDB();updateCount();renderDelList();
  applyFilter();page=1;renderSongList();
  document.getElementById("db-tag").textContent="(modificada)";
  const st=document.getElementById("del-status");st.textContent=`✓ Canciones eliminadas. Quedan ${SONGS.length} en la base.`;st.className="mstatus ok";
});

/* Export DB */
document.getElementById("btn-export-db").addEventListener("click",()=>{
  const data=JSON.stringify(SONGS.map(toHolyricsFormat),null,2);
  const a=document.createElement("a");
  a.href=URL.createObjectURL(new Blob([data],{type:"application/json"}));
