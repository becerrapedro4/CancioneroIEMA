    try{
      const raw=JSON.parse(e.target.result);
      if(!Array.isArray(raw)||(!raw[0]?.title&&!raw[0]?.t))throw new Error();
      // MERGE: add new songs, skip deleted and already existing
      const existingIds=new Set(SONGS.map(s=>s.id));
      const newSongs=raw.map(slimSong).filter(s=>!existingIds.has(s.id)&&!deletedIds.has(s.id));
      SONGS=[...SONGS,...newSongs];
      saveDB();updateCount();deleteMarked.clear();renderDelList();
      applyFilter();page=1;renderSongList();
      document.getElementById("db-tag").textContent="(modificada)";
      const st=document.getElementById("admin-status");
      st.textContent=newSongs.length?`✓ ${newSongs.length} canciones nuevas agregadas (total: ${SONGS.length})`:`✓ Sin canciones nuevas. Total: ${SONGS.length}`;
      st.className="mstatus ok";
    }catch{
